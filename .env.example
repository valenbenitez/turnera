# Cliente Firebase (público)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Servidor — Firebase Admin (elegí UNA opción):
# A) Archivo JSON descargado de Firebase (recomendado; evita JSON multilínea en .env)
# FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-adminsdk.json
#
# B) JSON minificado en UNA sola línea en .env (si partís el JSON en varias líneas sin comillas,
#    dotenv solo guarda el primer carácter y verifyIdToken falla con "Token inválido").
# El "project_id" del JSON debe coincidir con NEXT_PUBLIC_FIREBASE_PROJECT_ID.
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...",...}
